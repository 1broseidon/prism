{
  "listen_addr": ":9100",
  "issuer": "http://localhost:9100",
  "signing_key": {},
  "token_ttl_seconds": 3600,
  "clients": [
    {
      "client_id": "ci-agent",
      "client_secret": "ci-secret-change-me",
      "allowed_scopes": ["mcp:connect", "github:create_issue", "github:list_prs"],
      "description": "CI/CD pipeline agent"
    },
    {
      "client_id": "analyst",
      "client_secret": "analyst-secret-change-me",
      "allowed_scopes": ["mcp:connect", "dns:check-dns", "fs:read_file"],
      "description": "Data analyst agent"
    },
    {
      "client_id": "admin",
      "client_secret": "admin-secret-change-me",
      "allowed_scopes": ["mcp:connect", "github:*", "dns:*", "fs:*"],
      "description": "Admin agent with full access"
    }
  ]
}
