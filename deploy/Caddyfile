# Prism reverse proxy — single-hostname consolidation.
#
# Everything reachable under https://mcp.dfam.one (port 443):
#   /mcp, /mcp/*                                → gateway   (prism:8080)
#   /token, /authorize, /register               → gateway   (DCR OAuth 2.1)
#   /.well-known/oauth-protected-resource*      → gateway   (RFC 9728)
#   /.well-known/oauth-authorization-server     → gateway   (RFC 8414)
#   /.well-known/jwks.json                      → gateway
#   /workspace/*                                → gateway   (local bridge control plane)
#   everything else (/, /auth/*, /api-ish, ...) → admin     (prism:9086)
#
# Gateway and admin own non-overlapping paths so the split is safe.
#
# TLS uses Let's Encrypt DNS-01 via Cloudflare, so mcp.dfam.one can resolve
# to a private LAN address while clients still receive a public-trusted cert.
# Required env var in the Caddy container:
#   CLOUDFLARE_API_TOKEN
#
# Settings page must have:
#   public_url       = https://mcp.dfam.one
#   admin_public_url = https://mcp.dfam.one
#   trust_proxy_headers = on
{
	# Disable Caddy's admin endpoint — not used, smaller attack surface.
	admin off
}

mcp.dfam.one {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	encode gzip zstd

	@gateway {
		path /mcp /mcp/*
		path /token
		path /authorize
		path /register
		path /workspace/*
		path /.well-known/oauth-protected-resource
		path /.well-known/oauth-protected-resource/*
		path /.well-known/oauth-authorization-server
		path /.well-known/jwks.json
	}
	reverse_proxy @gateway prism:8080

	reverse_proxy prism:9086
}
