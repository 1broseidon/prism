# Prism reverse proxy.
#
# This setup terminates TLS with Caddy's internal CA (self-signed).
# It's appropriate when prism is only reachable on an internal network
# (mcp.dfam.one resolved via your home DNS, not on the public internet)
# so Let's Encrypt's HTTP-01 challenge can't reach the host.
#
# One-time trust setup so browsers stop warning:
#   docker compose exec caddy cat /data/caddy/pki/authorities/local/root.crt > caddy-root.crt
#   # then import caddy-root.crt into your OS / browser trust store.
#
# After Caddy is running:
#   - Open the admin: https://mcp.dfam.one
#   - Set "admin public url" to https://mcp.dfam.one and toggle
#     "trust reverse-proxy headers" on, so OAuth callbacks use the
#     external hostname instead of the in-container Host.
#
# If you later expose this to the public internet, drop `tls internal`
# and Caddy will obtain a Let's Encrypt cert automatically (needs ports
# 80 and 443 reachable from the internet).

{
	# Disable Caddy's admin endpoint — not used, smaller attack surface.
	admin off
}

# Admin console + OAuth callbacks → port 443
mcp.dfam.one {
	tls internal
	encode gzip zstd
	reverse_proxy prism:9086
}

# MCP gateway → port 8443 (same domain, separate listener)
mcp.dfam.one:8443 {
	tls internal
	encode gzip zstd
	reverse_proxy prism:8080
}
