{
  "listen_addr": ":8080",
  "admin_addr": ":9090",
  "resource_uri": "https://mcpgate.example.com",

  "auth": {
    "oauth": {
      "issuer_url": "https://auth.example.com/realms/mcp",
      "audience": "https://mcpgate.example.com",
      "required_scopes": ["mcp:connect"],
      "scopes_supported": [
        "mcp:connect",
        "github:*",
        "github:create_issue",
        "github:list_prs",
        "fs:read_file",
        "fs:write_file",
        "fs:*"
      ],
      "max_token_age": "1h"
    }
  },

  "servers": [
    {
      "id": "github",
      "url": "http://localhost:3001/mcp",
      "namespace": "github",
      "auth": {
        "header": "Authorization",
        "value": "Bearer $GITHUB_MCP_TOKEN"
      },
      "circuit_breaker": {
        "threshold": 5,
        "timeout": "30s",
        "max_half_open": 2
      }
    },
    {
      "id": "filesystem",
      "url": "http://localhost:3002/mcp",
      "namespace": "fs"
    }
  ],

  "rate_limit": {
    "requests_per_second": 50,
    "burst": 100
  },

  "shutdown_timeout": "10s"
}
